function scr_pop_up_text(arg0)
{
    var _text;
    
    switch (arg0)
    {
        case UnknownEnum.Value_0:
            _text = "This unit is not compatible.";
            break;
        
        case UnknownEnum.Value_1:
            _text = "Requires units in formation to raid.";
            break;
        
        case UnknownEnum.Value_2:
            _text = "Empty cage to start raid.";
            break;
        
        case UnknownEnum.Value_3:
            _text = "Empty storage to start raid.";
            break;
        
        case UnknownEnum.Value_4:
            _text = "Free up space in prison to auto insert cage units.";
            break;
        
        case UnknownEnum.Value_5:
            _text = "Select a destination before raid.";
            break;
        
        case UnknownEnum.Value_6:
            _text = "Can only be edited when in base.";
            break;
        
        case UnknownEnum.Value_7:
            _text = "This unit can only be placed in the front.";
            break;
        
        case UnknownEnum.Value_8:
            _text = "This unit can only be placed in the back.";
            break;
        
        case UnknownEnum.Value_9:
            _text = "The raiding party defeated the enemy.";
            break;
        
        case UnknownEnum.Value_10:
            _text = "The raiding party was defeated.";
            break;
        
        case UnknownEnum.Value_11:
            _text = "The Caravan has returned from the raid.";
            break;
        
        case UnknownEnum.Value_12:
            _text = "New quest added.";
            break;
        
        case UnknownEnum.Value_13:
            _text = "New cell type added.";
            break;
        
        case UnknownEnum.Value_14:
            _text = "New prop type added.";
            break;
        
        case UnknownEnum.Value_15:
            _text = "At least 1 Goblin needs to be in the nest.";
            break;
        
        case UnknownEnum.Value_16:
            _text = "Remove the infant from the cell.";
            break;
        
        case UnknownEnum.Value_17:
            _text = "At least one entrance is required.";
            break;
        
        case UnknownEnum.Value_18:
            _text = "Reached maximum troop raid capacity.";
            break;
        
        case UnknownEnum.Value_19:
            _text = "Formation Row is full, clear a spot to insert unit.";
            break;
        
        case UnknownEnum.Value_20:
            _text = "Trader is intimidated.";
            break;
        
        case UnknownEnum.Value_21:
            _text = "Game saved at slot 1.";
            break;
        
        case UnknownEnum.Value_22:
            _text = "Game saved at slot 2.";
            break;
        
        case UnknownEnum.Value_23:
            _text = "Game saved at slot 3.";
            break;
        
        case UnknownEnum.Value_24:
            _text = "Save file deleted.";
            break;
        
        case UnknownEnum.Value_25:
            _text = "Game auto saved.";
            break;
        
        case UnknownEnum.Value_26:
            _text = "The Caravan was attacked and robbed on it's way back.";
            break;
        
        case UnknownEnum.Value_27:
            _text = "Captured Elves were saved by Selene's Grace.";
            break;
        
        case UnknownEnum.Value_28:
            _text = "Morrigan's destruction wiped out many troops.";
            break;
        
        case UnknownEnum.Value_29:
            _text = "The Unstable tower wiped out many troops.";
            break;
        
        case UnknownEnum.Value_30:
            _text = "Unable to make changes, you have reached the border of the cave.";
            break;
        
        case UnknownEnum.Value_31:
            _text = "Tentacles reject anything not of their kind.";
            break;
        
        case UnknownEnum.Value_32:
            _text = "Formation does not have sufficient AP to conduct the raid.";
            break;
        
        case UnknownEnum.Value_33:
            _text = "Some of your troops have died from starvation.";
            break;
        
        case UnknownEnum.Value_34:
            _text = "Troop formation has been saved.";
            break;
        
        case UnknownEnum.Value_35:
            _text = "Troop formation has been loaded.";
            break;
        
        case UnknownEnum.Value_36:
            _text = "Can't save an empty troop formation.";
            break;
        
        case UnknownEnum.Value_37:
            _text = "No troop formation saved.";
            break;
        
        case UnknownEnum.Value_38:
            _text = "The Caravan is away on a raid.";
            break;
        
        case UnknownEnum.Value_39:
            _text = "There are no items in the Caravan.";
            break;
        
        case UnknownEnum.Value_40:
            _text = "The cage is empty.";
            break;
        
        case UnknownEnum.Value_41:
            _text = "A new floor upgrade can be purchased in the shop.";
            break;
        
        case UnknownEnum.Value_42:
            _text = "One of your fresh captives has mysteriously vanished without a trace.";
            break;
    }
    
    return _text;
}

enum UnknownEnum
{
    Value_0,
    Value_1,
    Value_2,
    Value_3,
    Value_4,
    Value_5,
    Value_6,
    Value_7,
    Value_8,
    Value_9,
    Value_10,
    Value_11,
    Value_12,
    Value_13,
    Value_14,
    Value_15,
    Value_16,
    Value_17,
    Value_18,
    Value_19,
    Value_20,
    Value_21,
    Value_22,
    Value_23,
    Value_24,
    Value_25,
    Value_26,
    Value_27,
    Value_28,
    Value_29,
    Value_30,
    Value_31,
    Value_32,
    Value_33,
    Value_34,
    Value_35,
    Value_36,
    Value_37,
    Value_38,
    Value_39,
    Value_40,
    Value_41,
    Value_42
}
